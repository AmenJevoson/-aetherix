{
  "version": 2,
  "name": "aetherix",
  "buildCommand": "pnpm build",
  "devCommand": "pnpm dev",
  "outputDirectory": "dist/public",
  "installCommand": "corepack enable && pnpm install --frozen-lockfile",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/auth/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/health",
      "destination": "/api/index"
    },
    {
      "source": "/((?!assets/|__manus__/|favicon.ico).*)",
      "destination": "/index.html"
    }
  ]
}
